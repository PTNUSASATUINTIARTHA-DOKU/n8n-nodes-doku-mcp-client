{
  "name": "n8n-nodes-doku-mcp-client",
  "version": "1.3.5",
  "description": "DOKU MCP Client Official n8n node",
  "license": "MIT",
  "homepage": "https://www.doku.com",
  "keywords": [
    "n8n-community-node-package",
    "doku-mcp-client",
    "payment-gateway-mcp-client",
    "indonesia-payment-gateway-mcp-client",
    "n8n-nodes-doku-mcp-client"
  ],
  "author": {
    "name": "Syahrul Fathi",
    "email": "syahrul.fathi@doku.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PTNUSASATUINTIARTHA-DOKU/n8n-nodes-doku-mcp-client"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/DokuMcpServerApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/McpClientTool/McpClientTool.node.js"
    ],
    "strict": false
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "@types/node": "^24.6.0",
    "eslint": "9.32.0",
    "n8n-workflow": "^2.3.0",
    "prettier": "3.6.2",
    "release-it": "^20.0.0",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "overrides": {
    "change-case": "4.1.2"
  },
  "dependencies": {
    "@langchain/core": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "@n8n/client-oauth2": "^1.1.0",
    "langchain": "^1.1.1",
    "oauth-1.0a": "^2.2.6"
  }
}
